{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "npm run start || bun dev --port $PORT",
    "numReplicas": 1,
    "restartPolicy": "on_failure",
    "healthcheckPath": "/api/health"
  }
}
